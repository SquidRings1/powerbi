{
  "powerbi_deployment": {
    "version": "1.0",
    "projectName": "FlavorOps Dashboard",
    "projectDescription": "AWS Instance Flavor Operations Dashboard with Power BI",
    "created": "2024",
    "status": "ready_for_deployment",
    "quick_start": {
      "step_1": "Run: python scripts/full_setup.py",
      "step_2": "Open: FlavorOps_Dashboard_Template.pbix in Power BI Desktop",
      "step_3": "Load: All 5 CSV files from data/ folder",
      "step_4": "Apply: Close & Apply to see dashboard"
    },
    "components": {
      "data_files": {
        "location": "data/",
        "format": "CSV",
        "encoding": "UTF-8",
        "delimiter": ",",
        "tables": [
          {
            "name": "Flavors",
            "file": "flavors.csv",
            "rows": 10,
            "columns": ["FlavorName", "VCpu", "Memory"],
            "description": "AWS instance types"
          },
          {
            "name": "Apps",
            "file": "apps.csv",
            "rows": 15,
            "columns": ["AppID", "AppName", "Environment", "Owner"],
            "description": "Applications"
          },
          {
            "name": "Instances",
            "file": "instances.csv",
            "rows": 50,
            "columns": ["InstanceID", "AppID", "FlavorName", "Status", "LaunchDate", "CostDaily"],
            "description": "VM instances"
          },
          {
            "name": "Metrics",
            "file": "metrics.csv",
            "rows": 1500,
            "columns": ["MetricID", "InstanceID", "Date", "CPU_P50", "CPU_P95", "RAM_P50", "RAM_P95"],
            "description": "CPU and RAM metrics"
          },
          {
            "name": "Timeline",
            "file": "timeline.csv",
            "rows": 14,
            "columns": ["TimelineID", "AppID", "Month", "Corrected", "Total"],
            "description": "Monthly evolution"
          }
        ]
      },
      "powerbi_template": {
        "file": "FlavorOps_Dashboard_Template.pbix",
        "format": ".pbix (Power BI Desktop format)",
        "minVersion": "2022.1",
        "includes": {
          "data_model": {
            "tables": 5,
            "relationships": 4,
            "description": "Star schema with dimensions and facts"
          },
          "dax_measures": {
            "count": 30,
            "examples": [
              "Count_Total",
              "Count_Critique", 
              "Count_Corrected",
              "Avg_CPU_P95",
              "Avg_RAM_P95",
              "Correction_Rate",
              "Total_Spend"
            ]
          },
          "dashboard_pages": [
            {
              "name": "Vue Globale",
              "order": 1,
              "visuals": ["KPI Cards", "Donut Chart", "Line Chart", "Data Table"],
              "interactive": true
            },
            {
              "name": "Détail App",
              "order": 2,
              "visuals": ["Slicers", "KPI Cards", "Bar Chart", "Data Table"],
              "interactive": true
            },
            {
              "name": "Instances & Config",
              "order": 3,
              "visuals": ["Dropdowns", "Pie Chart", "Gauge", "Data Table"],
              "interactive": true
            }
          ],
          "theme": {
            "name": "GitHub Dark",
            "palette": {
              "primary": "#2196F3",
              "critical": "#D32F2F",
              "warning": "#FF6D00",
              "success": "#00C853",
              "secondary": "#7C4DFF",
              "accent": "#00BCD4",
              "background": "#0D1117",
              "surface": "#161B22"
            }
          }
        }
      },
      "python_scripts": {
        "location": "scripts/",
        "required_version": "3.7+",
        "dependencies": ["pandas>=1.3.0", "numpy>=1.21.0"],
        "scripts": [
          {
            "name": "full_setup.py",
            "purpose": "One-click setup (data + template)",
            "executes": ["generate_data.py", "create_powerbi_template.py"],
            "output": ["All CSVs", "Template .pbix", "Config files"]
          },
          {
            "name": "generate_data.py",
            "purpose": "Generate CSV data files",
            "output": "5 CSV files in data/ folder",
            "features": ["Seeded RNG", "Realistic patterns", "Reproducible"]
          },
          {
            "name": "create_powerbi_template.py",
            "purpose": "Create Power BI template",
            "output": "FlavorOps_Dashboard_Template.pbix",
            "features": ["Model", "Relationships", "Measures", "Visualizations", "Theme"]
          },
          {
            "name": "powerbi_python_load.py",
            "purpose": "Python connector for Power BI",
            "usage": "Copy-paste into Power BI Script Editor",
            "features": ["Direct CSV loading", "Type conversion", "Date parsing"]
          },
          {
            "name": "deployment_manager.py",
            "purpose": "Validate setup and configuration",
            "features": ["Validation", "Config generation", "Metrics reporting"]
          }
        ]
      }
    },
    "workflows": {
      "initial_setup": {
        "name": "Initial Setup",
        "steps": 3,
        "duration": "3 minutes",
        "steps_list": [
          {
            "step": 1,
            "action": "Run setup script",
            "command": "python scripts/full_setup.py",
            "duration": "30 seconds"
          },
          {
            "step": 2,
            "action": "Open template in Power BI",
            "command": "File → Open → FlavorOps_Dashboard_Template.pbix",
            "duration": "30 seconds"
          },
          {
            "step": 3,
            "action": "Load CSV files",
            "command": "Home → Transform Data → CSV",
            "duration": "2 minutes"
          }
        ]
      },
      "data_refresh": {
        "name": "Data Refresh",
        "steps": 2,
        "duration": "1 minute",
        "steps_list": [
          {
            "step": 1,
            "action": "Regenerate data",
            "command": "python scripts/generate_data.py"
          },
          {
            "step": 2,
            "action": "Refresh in Power BI",
            "command": "Ctrl+R (Windows) or Cmd+R (Mac)"
          }
        ]
      },
      "cloud_deployment": {
        "name": "Cloud Deployment to Power BI Service",
        "prerequisites": ["Power BI Pro subscription", "Power BI Desktop"],
        "steps": 5,
        "steps_list": [
          {
            "step": 1,
            "action": "Open template",
            "command": "File → Open → FlavorOps_Dashboard_Template.pbix"
          },
          {
            "step": 2,
            "action": "Publish to cloud",
            "command": "Home → Publish"
          },
          {
            "step": 3,
            "action": "Select workspace",
            "command": "Choose destination workspace"
          },
          {
            "step": 4,
            "action": "Configure data refresh",
            "command": "Power BI Service → Settings → Scheduled Refresh"
          },
          {
            "step": 5,
            "action": "Share with team",
            "command": "Report → Share"
          }
        ]
      }
    },
    "documentation": {
      "quick_reference": "DEMARRAGE_RAPIDE.md",
      "full_guide": "POWERBI_TEMPLATE_GUIDE.md",
      "complete_reference": "POWERBI_COMPLETE_GUIDE.md",
      "dax_formulas": "DAX_MEASURES_REFERENCE.md",
      "power_query": "POWERQUERY_EXAMPLES.md",
      "summary": "FINAL_SETUP_SUMMARY.md",
      "skill": ".github/skills/powerbi/SKILL.md"
    },
    "requirements": {
      "system": {
        "os": ["Windows 10+", "macOS 10.15+", "Linux"],
        "ram": "8GB minimum",
        "disk_space": "500MB"
      },
      "software": {
        "python": "3.7+",
        "power_bi": "Desktop 2022 or later",
        "optional": ["Power BI Premium for cloud features"]
      },
      "packages": {
        "pandas": ">=1.3.0",
        "numpy": ">=1.21.0"
      }
    },
    "features": {
      "dashboard": {
        "pages": 3,
        "interactive_slicers": true,
        "drill_through": true,
        "bookmarks": true,
        "themes": ["GitHub Dark (default)", "Light (custom)"]
      },
      "data_model": {
        "tables": 5,
        "relationships": 4,
        "measures": 30,
        "calculated_columns": 8
      },
      "analytics": {
        "kpi_metrics": ["Total Instances", "Critical Count", "Correction Rate", "Total Cost"],
        "visualizations": ["KPI Cards", "Donut Charts", "Line Charts", "Bar Charts", "Tables"],
        "colors_status": {
          "CRITIQUE": "#D32F2F",
          "SUR-CONSO": "#FF6D00",
          "OK": "#00C853",
          "SOUS-CONSO": "#2196F3"
        }
      }
    },
    "troubleshooting": {
      "common_issues": [
        {
          "issue": "Python not found",
          "solution": "Install Python 3.7+ from python.org"
        },
        {
          "issue": "pandas not found",
          "solution": "Run: pip install pandas numpy"
        },
        {
          "issue": "CSV files missing",
          "solution": "Run: python scripts/generate_data.py"
        },
        {
          "issue": "No data in dashboard",
          "solution": "Refresh: Ctrl+R (Cmd+R on Mac)"
        },
        {
          "issue": "Relationship errors",
          "solution": "Check Model tab → Manage Relationships"
        }
      ]
    },
    "next_steps": [
      "Run: python scripts/full_setup.py",
      "Open: FlavorOps_Dashboard_Template.pbix",
      "Load: CSV files from data/ folder",
      "Explore: Dashboard pages and interact with slicers",
      "Customize: Modify colors, measures, or visualizations",
      "Deploy: Publish to Power BI Service (optional)",
      "Share: Share reports with team"
    ],
    "support_resources": {
      "microsoft_docs": "https://docs.microsoft.com/power-bi",
      "dax_reference": "https://dax.guide",
      "power_query_docs": "https://docs.microsoft.com/power-query",
      "pandas_docs": "https://pandas.pydata.org/docs"
    },
    "version_history": {
      "1.0": {
        "date": "2024",
        "status": "Initial Release",
        "features": [
          "Complete Power BI template",
          "Data generation scripts",
          "30+ DAX measures",
          "3 interactive dashboard pages",
          "Dark theme",
          "Comprehensive documentation"
        ]
      }
    }
  }
}
